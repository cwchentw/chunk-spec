#!/usr/bin/env perl

use v5.36;
use utf8;

binmode(STDOUT, ':utf8');

use FindBin;
use lib "$FindBin::Bin/../lib";
use local::lib "$FindBin::Bin/../local";

use JSON;

use ChunkSpec::Lexer;
use ChunkSpec::Parser;
use ChunkSpec::IR;


use constant {
    PROGRAM => 'md2chunk',
    VERSION => '0.1.0',
};


if ((scalar @ARGV) < 1) {
    say { \*STDERR } "Error: No input file";
    say { \*STDERR } "";
    print_help(\*STDERR);
    exit 1;
}

my $grammar_file;
while (@ARGV) {
    my $arg = shift @ARGV;

    if ($arg eq '-v' or $arg eq '--version') {
        print_version();
        exit;
    }
    elsif ($arg eq '-h' or $arg eq '--help') {
        print_help(\*STDOUT);
        exit;
    }
    elsif (index($arg, '-') == 0) {
        say { \*STDERR } "Error: Unknown argument: $arg";
        say { \*STDERR } "";
        print_help(\*STDERR);
        exit 1;
    }

    $grammar_file = $arg;
    last;
}

(-e $grammar_file) or die "Error: Grammar file not found: $grammar_file\n";

open(my $FH, '<:encoding(UTF-8)', $grammar_file) or die "Unable to open $grammar_file";

# 抽出 chunkspec block
my $in_block = 0;
my @chunkspec_lines;
my $line_number = 1;
my $lexer = ChunkSpec::Lexer->new();
while (my $line = <$FH>) {
    if ($line =~ /^```chunkspec/) {
        $in_block = 1;
        $line_number++;
        next;
    }
    if ($line =~ /^```$/) {
        $in_block = 0;
        $line_number++;
        next;
    }

    if ($in_block) {
        $lexer->lex($line, $line_number);
    }

    $line_number++;
}
close $FH;

my $parser = ChunkSpec::Parser->new();
$parser->parse($lexer);

my $ir = ChunkSpec::IR->new()->emit($parser);

say JSON->new->canonical(0)->encode($ir);

sub print_version() {
    say VERSION;
}

sub print_help($stream) {
    print $stream <<~EOL_HELP
Usage: $0 [option] grammar-chunk.txt"

Option:
    -v    --version    Show version info
    -h    --help       Show help info
EOL_HELP
}
